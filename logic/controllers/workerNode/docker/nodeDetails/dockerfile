# Lightweight Node base
FROM node:20-alpine

# Install system tools + OpenCL runtime
RUN apk add --no-cache \
    bash \
    util-linux \
    pciutils \
    curl \
    ca-certificates \
    opencl-dev \
    opencl-icd-loader \
    build-base \
    python3 \
    make \
    g++

# Create app directory
WORKDIR /app

# Copy package files first (better Docker caching)
COPY package*.json ./

# Install node dependencies
RUN npm install --production

# Copy application
COPY . .

# Optional check for OpenCL
RUN if command -v clinfo >/dev/null 2>&1; then clinfo; else echo "clinfo not installed"; fi

# Start worker node
CMD ["node", "image/nodeDetails.js"]